<Window x:Class="ZemaxMCP.Launcher.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Zemax MCP Setup" Width="860" Height="720" MinWidth="760" MinHeight="620" WindowStartupLocation="CenterScreen" Loaded="OnLoaded">
  <Window.Resources>
    <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="#F7F9FC"/><Setter Property="BorderBrush" Value="#D9E1EC"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="7"/><Setter Property="Padding" Value="14"/></Style>
    <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Padding" Value="12,6"/><Setter Property="Margin" Value="0,0,8,0"/><Setter Property="MinWidth" Value="88"/></Style>
    <Style x:Key="SectionLabel" TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#334155"/><Setter Property="Margin" Value="0,0,0,7"/></Style>
  </Window.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Zemax MCP" FontSize="25" FontWeight="SemiBold"/><TextBlock Text="OpticStudio HTTP MCP service and AI client setup" Foreground="#64748B" Margin="0,3,0,0"/></StackPanel><Button Grid.Column="1" Content="Exit" Padding="14,7" VerticalAlignment="Center" Click="Exit_Click"/></Grid>

    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,18,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="OpticStudio installation" Style="{StaticResource SectionLabel}"/><ComboBox x:Name="ZemaxVersions" DisplayMemberPath="DisplayName" SelectionChanged="ZemaxVersions_SelectionChanged"/><CheckBox x:Name="StartOnLogin" Content="Start Zemax MCP when I sign in" Margin="0,10,0,0" Checked="StartOnLogin_Changed" Unchecked="StartOnLogin_Changed"/></StackPanel><StackPanel Grid.Column="1" Margin="18,0,0,0"><TextBlock Text="Network" Style="{StaticResource SectionLabel}"/><CheckBox x:Name="ShareOnLan" Content="Share with a trusted LAN computer" Checked="ShareOnLan_Changed" Unchecked="ShareOnLan_Changed"/><StackPanel Orientation="Horizontal" Margin="0,8,0,0"><TextBlock Text="Port" VerticalAlignment="Center" Foreground="#64748B"/><TextBox x:Name="Port" Text="8000" Width="80" Margin="10,0,0,0"/></StackPanel></StackPanel></Grid></Border>

    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0"><StackPanel><TextBlock Text="MCP address" Style="{StaticResource SectionLabel}"/><TextBlock x:Name="Endpoint" Foreground="#334155" FontWeight="SemiBold"/><TextBlock Text="Remote MCP URL (only on a second computer)" Foreground="#64748B" Margin="0,12,0,3"/><TextBox x:Name="RemoteEndpoint" ToolTip="Paste the address copied from the OpticStudio computer"/></StackPanel></Border>

    <Grid Grid.Row="3" Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><StackPanel Orientation="Horizontal"><Ellipse x:Name="McpStateDot" Width="11" Height="11" Fill="#94A3B8" Margin="0,2,7,0"/><TextBlock Text="MCP service" FontWeight="SemiBold"/></StackPanel><TextBlock x:Name="McpState" Text="Not checked" Foreground="#64748B" Margin="18,5,0,0" TextWrapping="Wrap"/></StackPanel></Border>
      <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0"><StackPanel><StackPanel Orientation="Horizontal"><Ellipse x:Name="ZosStateDot" Width="11" Height="11" Fill="#94A3B8" Margin="0,2,7,0"/><TextBlock Text="OpticStudio / ZOS-API" FontWeight="SemiBold"/></StackPanel><TextBlock x:Name="ZosState" Text="Not checked" Foreground="#64748B" Margin="18,5,0,0" TextWrapping="Wrap"/></StackPanel></Border>
      <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0"><StackPanel><StackPanel Orientation="Horizontal"><Ellipse x:Name="AiStateDot" Width="11" Height="11" Fill="#94A3B8" Margin="0,2,7,0"/><TextBlock Text="AI client activity" FontWeight="SemiBold"/></StackPanel><TextBlock x:Name="AiState" Text="No client call recorded" Foreground="#64748B" Margin="18,5,0,0" TextWrapping="Wrap"/></StackPanel></Border>
    </Grid>

    <Grid Grid.Row="4" Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Server control" Style="{StaticResource SectionLabel}"/><WrapPanel><Button Content="Start" Style="{StaticResource ActionButton}" Click="Start_Click"/><Button Content="Stop" Style="{StaticResource ActionButton}" Click="Stop_Click"/><Button Content="Refresh status" Style="{StaticResource ActionButton}" Click="RefreshStatus_Click"/><Button Content="Test connection" Style="{StaticResource ActionButton}" Click="TestMcp_Click"/></WrapPanel></StackPanel></Border>
      <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0"><StackPanel><TextBlock Text="AI client setup" Style="{StaticResource SectionLabel}"/><Button x:Name="AiConfigButton" Content="Configure AI clients ▾" Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Click="AiConfigMenu_Click"><Button.ContextMenu><ContextMenu><MenuItem Header="Configure all detected clients" Click="ConfigureDetected_Click"/><Separator/><MenuItem Header="Configure Codex" Click="Codex_Click"/><MenuItem Header="Configure Claude Desktop" Click="Claude_Click"/><MenuItem Header="Configure Cursor" Click="Cursor_Click"/></ContextMenu></Button.ContextMenu></Button></StackPanel></Border>
      <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Orientation="Horizontal"><Button Content="Copy address" Style="{StaticResource ActionButton}" Click="CopyEndpoint_Click"/><Button Content="Logs" Style="{StaticResource ActionButton}" Click="OpenLogs_Click"/><Button Content="Updates" Style="{StaticResource ActionButton}" Margin="0" Click="Update_Click"/></StackPanel>
    </Grid>

    <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,16,0,0" MinHeight="150"><StackPanel><TextBlock Text="Connection details" Style="{StaticResource SectionLabel}"/><TextBlock x:Name="ConnectionSummary" Text="Refresh status to check the endpoint." TextWrapping="Wrap" Foreground="#475569"/><TextBox x:Name="Status" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="75" Margin="0,10,0,0"/></StackPanel></Border>
    <TextBlock Grid.Row="6" Text="Green: ready · Amber: waiting or needs attention · Red: unavailable. The bridge writes logs beside the installed application." Foreground="#64748B" TextWrapping="Wrap" Margin="0,14,0,0"/>
  </Grid></ScrollViewer>
</Window>
